.venv/
__pycache__/
*.pyc
.env
.DS_Store
node_modules/
.next/
dist/
build/
*.log
.gemini/

# .agents/skills/ is source code (agent personas) — must be committed so the
# ADK root_agent works on a fresh clone. Only local ADK scratch state is ignored.
.agents/.cache/

# Demo dataset (courses, users, generated learning paths) is committed so the
# app works out of the box on a fresh clone / new machine — see README.
# Only genuinely derived/runtime output stays ignored (each pattern's comment
# MUST be on its own line — git does not support inline "pattern # comment"):
# Tier 2 KPI payloads — regenerated from user_progress
data/kpi_store/
# KB conflict alerts — regenerated by kb_validator
data/conflicts/
# active quiz sessions — ephemeral, regenerated per attempt
data/quizzes/
# async KB upload job status — ephemeral, regenerated per upload
data/kb_jobs/
data/knowledge_base/*/gap_cache/

# Personal working notes / brainstorming / business strategy docs — not app
# source, kept local-only on purpose.
AI_Research/Brain/
