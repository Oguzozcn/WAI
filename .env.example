# WisdomAI MVP — environment contract (copy to .env for local dev).
#
# .env is gitignored and NEVER shipped in the container image. On Cloud Run
# these are set as service env vars; the sensitive one (WAI_CREDENTIALS_JSON)
# comes from Secret Manager. This file is the single source of truth for every
# knob the app reads — keep it in sync with src/core/settings.py.

# ── Google AI (Vertex/Gemini) ────────────────────────────────────────────────
# On Cloud Run these authenticate automatically via the service account (ADC);
# locally you run `gcloud auth application-default login` once.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# ── Storage backend ──────────────────────────────────────────────────────────
# local  = JSON + binaries on the local filesystem under data/ (default; works
#          offline on either laptop — nothing cloud is required).
# cloud  = JSON docs in Firestore, binary blobs (PDFs/images/audio, version
#          snapshots) in a GCS bucket. Requires the two settings below.
STORAGE=local
WAI_GCS_BUCKET=            # e.g. your-project-wai-data  (required when STORAGE=cloud)
WAI_FIRESTORE_DATABASE=(default)   # Firestore database id; "(default)" unless you made a named one
WAI_FIRESTORE_PREFIX=wai           # collection-name prefix, namespaces this app's data

# ── Auth / credentials ───────────────────────────────────────────────────────
# The login accounts live in data/credentials.json (bcrypt-hashed passwords).
# In cloud, supply the file's CONTENT via Secret Manager as WAI_CREDENTIALS_JSON
# instead of shipping the file — it takes precedence over the on-disk file.
WAI_CREDENTIALS_JSON=              # (cloud) full credentials.json content, injected from Secret Manager
# WAI_CREDENTIALS_PATH=data/credentials.json   # (optional) override the local file path

# When true, trust Google IAP's signed identity header
# (X-Goog-Authenticated-User-Email) as the logged-in user. Turn this on ONLY when
# the service actually sits behind IAP — otherwise the header can be spoofed.
WAI_TRUST_IAP=false
