# WisdomAI MVP Environment Configuration
# Copy this file to `.env` and fill in your own values. `.env` itself is
# gitignored — never commit real project IDs/credentials.
#
# Auth uses Application Default Credentials (ADC), not an API key:
#   gcloud auth application-default login

GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
