# Keep the build context (and image) small and free of local-only state.
.git
.gitignore
.venv
venv
__pycache__
**/__pycache__
*.pyc
*.pyo
.pytest_cache
.ruff_cache
.mypy_cache
.DS_Store

# Local secrets / env — supplied at runtime via Cloud Run env / Secret Manager,
# never baked into the image.
.env
.env.*
!.env.example

# Editor / IDE
.vscode
.idea

# Local-only working notes and scratch (also gitignored)
AI_Research/Brain
.gemini
.agents/.cache

# Runtime/generated data that must NOT ship in the image — regenerated at runtime
# or lives in Firestore/GCS in cloud mode. The committed demo dataset under data/
# is intentionally NOT ignored (seeds local/volume mode + the Firestore import).
data/kpi_store
data/conflicts
data/quizzes
data/kb_jobs
data/knowledge_base/*/gap_cache
